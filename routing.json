{
  "rule_set": [
    {
      "type": "remote",
      "tag": "geosite-ru-extended",
      "format": "binary",
      "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-ru.srs",
      "download_detour": "proxy",
      "update_interval": "7d"
    }
  ],
  "rules": [
    {
      "ip_is_private": true,
      "outbound": "direct"
    },
    {
      "geoip": ["ru", "by", "su"],
      "outbound": "direct"
    },
    {
      "geosite": ["ru"],
      "outbound": "direct"
    },
    {
      "rule_set": ["geosite-ru-extended"],
      "outbound": "direct"
    },
    {
      "domain_regex": [
        ".*\\.ru$",
        ".*\\.su$",
        ".*\\.рф$",
        ".*\\.xn--p1ai$",
        ".*\\.xn--80aswg$",
        ".*\\.xn--c1avg$",
        ".*\\.xn--80asehdb$",
        ".*\\.xn--p1acf$"
      ],
      "outbound": "direct"
    },
    {
      "domain_suffix": [
        ".su",
        ".by",
        ".xn--p1ai",
        ".xn--80aswg",
        ".xn--c1avg",
        ".xn--80asehdb",
        ".xn--p1acf"
      ],
      "outbound": "direct"
    },
    {
      "process_name": [
        "chrome.exe",
        "Arc.exe",
        "firefox.exe",
        "Tor Browser.exe",
        "Screenpresso.exe",
        "slack.exe",
        "TQ.exe",
        "perplexity.exe",
        "Perplexity.exe",
        "Discord.exe",
        "Loader.exe",
        "SideQuest.exe"
      ],
      "outbound": "proxy"
    },
    {
      "outbound": "proxy"
    }
  ]
}
